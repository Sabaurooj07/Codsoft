import java.util.Random;
import java.util.Scanner;
class Numbergame {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        Random random = new Random();
        char playAgain;
        do {
            int number = random.nextInt(101); // 0–100
            int attempt = 0;
            int maxattempts = 5;
            int score = 0;
            boolean correct = false;
            System.out.println("Guess the number (0-100)");
            while (attempt < maxattempts) {
                System.out.print("#Enter your guess: ");
                int n = sc.nextInt();
                attempt++;
                if (n == number) {
                    System.out.println("Correct!");
                    correct = true;
                    break;
                }
                if (n > number) {
                    System.out.println("Too High");
                } else {
                    System.out.println("Too Less");
                }
                int attemptsleft = maxattempts - attempt;
                System.out.println("Attempts left: " + attemptsleft);
            }
            if (correct) {
                if (attempt == 1) score = 100;
                else if (attempt == 2) score = 80;
                else if (attempt == 3) score = 50;
                else if (attempt == 4) score = 25;
                else if (attempt==5) score = 10;
            } else {
                System.out.println("Game Over");
                System.out.println("The number was: " + number);
            }
            System.out.println("Score: " + score);
            System.out.print("Play again? (y/n): ");
            playAgain = sc.next().charAt(0);
        } while (playAgain == 'y' || playAgain == 'Y');
        sc.close();
    }
}
